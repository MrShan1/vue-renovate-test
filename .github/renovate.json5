{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    ':label(dependencies, devops)',
    ':maintainLockFilesWeekly',
    ':automergeLinters',
    ':automergeTypes',
    ':automergeMinor',
    ':automergePatch',
  ],
  baseBranchPatterns: [
    'master',
  ],
  schedule: [
    '* * * * *',
  ],
}
